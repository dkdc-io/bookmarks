#!/usr/bin/env bash
set -euo pipefail

# Install rustup and uv if not already present.

if [[ "${CI:-}" == "true" ]] && command -v apt-get &>/dev/null; then
    echo "Installing Tauri Linux prerequisites..."
    sudo apt-get update
    sudo apt-get install -y \
        libwebkit2gtk-4.1-dev \
        build-essential \
        curl \
        wget \
        file \
        libxdo-dev \
        libssl-dev \
        libayatana-appindicator3-dev \
        librsvg2-dev
fi

if ! command -v rustup &>/dev/null; then
    echo "Installing rustup..."
    curl --proto '=https' --tlsv1.2 -LsSf https://sh.rustup.rs | sh -s -- -y
    . "$HOME/.cargo/env"
fi

if ! command -v uv &>/dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
fi

echo "Setup complete!"
